{
  "name": "eslint-stats",
  "version": "1.0.1",
  "description": "A package of custom formatters that show aggregated stats of eslint errors",
  "main": "index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "unit": "cross-env NODE_ENV=test nyc jasmine test/**/*.js",
    "test": "npm run lint && npm run unit",
    "coveralls": "nyc report --reporter=text-lcov | coveralls"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ganimomer/eslint-stats.git"
  },
  "author": {
    "name": "Omer Ganim",
    "email": "ganimomer@gmail.com",
    "url": "http://github.com/ganimomer"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.10",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
